{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONPATH=\"${CLAUDE_PLUGIN_ROOT}:${PYTHONPATH}\" python3 -m delivery_workflow.host_hooks safety-guard"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONPATH=\"${CLAUDE_PLUGIN_ROOT}:${PYTHONPATH}\" python3 -m delivery_workflow.host_hooks record-file-change"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONPATH=\"${CLAUDE_PLUGIN_ROOT}:${PYTHONPATH}\" python3 -m delivery_workflow.host_hooks record-command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONPATH=\"${CLAUDE_PLUGIN_ROOT}:${PYTHONPATH}\" python3 -m delivery_workflow.host_hooks stop-guard"
          }
        ]
      }
    ]
  }
}
