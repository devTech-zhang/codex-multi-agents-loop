#!/usr/bin/env python3
from __future__ import annotations

import os
import sys
from pathlib import Path

PLUGIN_ROOT = Path(__file__).resolve().parents[1]
VENV_PYTHON = PLUGIN_ROOT / ".venv" / "bin" / "python"
if VENV_PYTHON.exists() and os.environ.get("VIRTUAL_ENV") != str(PLUGIN_ROOT / ".venv"):
    env = os.environ.copy()
    env["VIRTUAL_ENV"] = str(PLUGIN_ROOT / ".venv")
    env["PATH"] = f"{PLUGIN_ROOT / '.venv' / 'bin'}:{env.get('PATH', '')}"
    os.execve(str(VENV_PYTHON), [str(VENV_PYTHON), __file__, *sys.argv[1:]], env)
sys.path.insert(0, str(PLUGIN_ROOT))

from delivery_workflow.mcp_server import main


if __name__ == "__main__":
    main()
